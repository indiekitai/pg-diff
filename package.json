{
  "name": "@indiekitai/pg-diff",
  "version": "0.1.0",
  "description": "PostgreSQL schema diff - generates migration SQL by comparing two databases",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "pg-diff": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "postgresql",
    "schema",
    "diff",
    "migration"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/indiekitai/pg-diff"
  },
  "publishConfig": {
    "access": "public"
  }
}
